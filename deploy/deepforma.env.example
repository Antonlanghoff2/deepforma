\
# Variables d'environnement de production pour Deepforma.
# Ne pas committer ce fichier avec de vrais secrets.

PYTHONUNBUFFERED=1

# France Travail
FRANCE_TRAVAIL_CLIENT_ID=
FRANCE_TRAVAIL_CLIENT_SECRET=
FRANCE_TRAVAIL_SCOPE=api_offresdemploiv2 o2dsoffre
FRANCE_TRAVAIL_TOKEN_URL=https://entreprise.francetravail.fr/connexion/oauth2/access_token?realm=/partenaire
FRANCE_TRAVAIL_API_BASE_URL=https://api.francetravail.io/partenaire/offresdemploi/v2
FRANCE_TRAVAIL_TIMEOUT=20

# Réglages applicatifs Deepforma
DEEPFORMA_CACHE_TTL_SECONDS=600
DEEPFORMA_MAX_OFFERS=25
DEEPFORMA_PAGE_SIZE=10
DEEPFORMA_MAX_PAGES=3
DEEPFORMA_DEFAULT_THRESHOLD=0.5
DEEPFORMA_MAX_LENGTH=512

# Caches Hugging Face / Transformers
HF_HOME=/opt/deepforma/.cache/huggingface
TRANSFORMERS_CACHE=/opt/deepforma/.cache/huggingface/transformers
TOKENIZERS_PARALLELISM=false
